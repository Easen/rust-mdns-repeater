{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Cargo launch",
            "env": {
                "RUST_LOG": "trace"
            },
            "cargo": {
                "args": [
                    "build",
                    "--manifest-path=Cargo.toml"
                ],
                "filter": {
                    "kind": "bin"
                }
            },
            "args": [
                "--disable-ipv6",
                "--interface",
                "eth0" ,
                "--interface",
                "eth1",
                "--interface",
                "br-46fb054cb02b",
            ]
        }
    ]
}